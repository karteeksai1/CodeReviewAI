NODE_ENV=development
API_PORT=3001
PUBLIC_API_URL=http://localhost:3001
JWT_SECRET=your-jwt-secret-here
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret-here
GITHUB_APP_ID=your-github-app-id-here
GITHUB_APP_PRIVATE_KEY="your-github-app-private-key-here"
GITHUB_APP_INSTALL_URL=https://github.com/apps/your-app-name/installations/new
GITHUB_POST_COMMENTS=true
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
DB_AUTO_MIGRATE=true
QUEUE_CONCURRENCY=3
AGENT_URL=http://localhost:8000
AGENT_PORT=8000
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_SECONDS=30
HUGGINGFACE_API_KEY=your-huggingface-api-key-here
HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HUGGINGFACE_TIMEOUT_SECONDS=45
EMBEDDING_DIMENSIONS=384
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX=codereview
NEXT_PUBLIC_API_URL=http://localhost:3001
